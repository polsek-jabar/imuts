// to ensure it runs before any HTML is output

// Helper function to format file size
function format_size($size) {
    $units = ['B', 'KB', 'MB', 'GB'];
    $unit_index = 0;
    while ($size >= 1024 && $unit_index < count($units) - 1) {
        $size /= 1024;
        $unit_index++;
    }
    return round($size, 2) . ' ' . $units[$unit_index];
}
